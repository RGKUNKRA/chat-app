# ============================================
# Server Environment Variables
# ============================================

# Node environment
NODE_ENV=production

# Server port
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chat-app?retryWrites=true&w=majority

# JWT secret for token generation
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Client URL (must match your frontend deployment domain)
# E.g., https://mychatapp.com, https://chat-app.vercel.app, https://chat-app.onrender.com
CLIENT_URL=https://your-frontend-domain.com

# ============================================
# Build-time Environment Variables (Frontend)
# Add these when building the client
# ============================================

# API URL for frontend (optional - auto-detected in production)
# Set only if your API is on a different domain
# REACT_APP_API_URL=https://api.example.com/api

# Socket URL for frontend (optional - auto-detected in production)
# Set only if your socket server is on a different domain
# REACT_APP_SOCKET_URL=https://api.example.com
